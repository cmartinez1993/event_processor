generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id              BigInt   @id @default(autoincrement())
  user_id         String
  event_type      String
  event_timestamp DateTime
  created_at      DateTime @default(now())

  @@index([event_type])
  @@map("events")
}
